flowchart TB
    subgraph SRC["Source data"]
        XL["AML Case.xlsx<br/>52k transactions · 2.5k KYC profiles · merchants"]
    end

    subgraph PIPE["Multi-agent pipeline (sequential DAG, audited)"]
        direction TB

        A1["<b>1. Data Agent</b><br/>schema validation<br/>rail coherence<br/>enrichment<br/>LLM quality assessment"]
        A2["<b>2. Detection Agent</b><br/>21-rule engine<br/>XGBoost ML scoring<br/>priority + severity<br/>LLM triage memo"]
        A3["<b>3. Investigation Agent</b><br/>evidence bundle<br/>evidence-weighted timeline<br/>entity links<br/>LLM case narrative"]
        A4["<b>4. SAR Agent</b><br/>structured JSON + markdown<br/>canonical rule citations<br/>sanctions distinction<br/>LLM drafting"]
        A5["<b>5. Compliance Agent</b><br/>deterministic policy checks<br/>severity-aware decision<br/>FATF / BACEN / COAF alignment<br/>LLM review"]

        A1 --> A2 --> A3 --> A4 --> A5
    end

    subgraph BACKENDS["Backends (per-agent)"]
        ANTH["Anthropic Claude<br/>(--use-llm)"]
        TPL["Deterministic templates<br/>(same JSON contract)"]
    end

    subgraph STORE["Artifact store · per-run dir"]
        ART["processed_transactions.parquet<br/>prioritized_alert_queue.json<br/>evidence_bundle.json<br/>investigation_case.json<br/>sar_structured.json + sar_draft.md<br/>compliance_review.json<br/>final_decision.json<br/>audit_log.json"]
    end

    ORC(["<b>Orchestrator</b><br/>stage routing · use_llm flag · audit logging"])

    XL --> ORC
    ORC --> A1
    A1 -.-> ANTH
    A1 -.-> TPL
    A2 -.-> ANTH
    A2 -.-> TPL
    A3 -.-> ANTH
    A3 -.-> TPL
    A4 -.-> ANTH
    A4 -.-> TPL
    A5 -.-> ANTH
    A5 -.-> TPL
    A1 --> ART
    A2 --> ART
    A3 --> ART
    A4 --> ART
    A5 --> ART

    classDef agent fill:#eef2ff,stroke:#4f46e5,stroke-width:1.5px,color:#1e1b4b
    classDef backend fill:#fef3c7,stroke:#d97706,stroke-width:1px,color:#78350f
    classDef store fill:#ecfdf5,stroke:#059669,stroke-width:1px,color:#064e3b
    classDef src fill:#fef2f2,stroke:#dc2626,stroke-width:1px,color:#7f1d1d
    classDef orch fill:#fafafa,stroke:#111827,stroke-width:2px,color:#111827

